{
  "deck": {
    "cols": 5,
    "rows": 3
  },
  "icons": {
    "test_icon": "icons/test_icon.png",
    "pause": "icons/pause.png",
    "forward": "icons/forward.png",
    "back": "icons/back.png"
  },
  "screens": [
    {
      "id": "default",
      "buttons": [
        {
          "position": {
            "x": 1,
            "y": 1
          },
          "style": {
            "text_align": "right",
            "text_size": 24
          },
          "template": "Counter: {plugin_test.counter}",
          "on_click_action": "plugin_test.increment",
          "icon": null
        },
        {
          "position": {
            "x": 2,
            "y": 2
          },
          "style": {
            "text_align": "center",
            "text_size": 24
          },
          "template": "",
          "on_click_action": "rustdeck_media.previous",
          "icon": "back"
        },
        {
          "position": {
            "x": 2,
            "y": 1
          },
          "style": {
            "text_align": "left",
            "text_size": 24
          },
          "template": "Clear counter",
          "on_click_action": "plugin_test.clear",
          "icon": null
        },
        {
          "position": {
            "x": 3,
            "y": 1
          },
          "style": {
            "text_align": "center",
            "text_size": 24
          },
          "template": "State: {rustdeck_media.state}\\nTitle: '{rustdeck_media.title}'\\nArtist: '{rustdeck_media.artist}'",
          "on_click_action": null,
          "icon": null
        },
        {
          "position": {
            "x": 5,
            "y": 1
          },
          "style": {
            "text_align": "center",
            "text_size": 24
          },
          "template": "",
          "on_click_action": null,
          "icon": "test_icon"
        },
        {
          "position": {
            "x": 4,
            "y": 2
          },
          "style": {
            "text_align": "center",
            "text_size": 24
          },
          "template": "",
          "on_click_action": "rustdeck_media.next",
          "icon": "forward"
        },
        {
          "position": {
            "x": 3,
            "y": 2
          },
          "style": {
            "text_align": "center",
            "text_size": 24
          },
          "template": "",
          "on_click_action": "rustdeck_media.play_pause",
          "icon": "pause"
        },
        {
          "position": {
            "x": 4,
            "y": 1
          },
          "style": {
            "text_align": "center",
            "text_size": 24
          },
          "template": "Switch to screen 2",
          "on_click_action": "deck.switch_screen:screen_2",
          "icon": null
        }
      ]
    },
    {
      "id": "screen_2",
      "buttons": [
        {
          "position": {
            "x": 1,
            "y": 1
          },
          "style": {
            "text_align": "center",
            "text_size": 24
          },
          "template": "Switch to screen 1",
          "on_click_action": "deck.switch_screen:default",
          "icon": null
        }
      ]
    }
  ]
}
